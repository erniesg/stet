# URL of the BT AI Tools CPI article review page
STET_CPI_URL=http://127.0.0.1:5002/cpi

# Trace collector port (default 5123)
STET_TRACE_PORT=5123

# How long to wait for the AI-generated article to appear (ms)
STET_ARTICLE_WAIT_MS=60000

# Extension dist path (relative to repo root)
STET_EXTENSION_PATH=packages/extension/dist
