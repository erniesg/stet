{
  "name": "stet",
  "version": "0.1.0",
  "description": "Pluggable prose linter — ESLint for writing. Sync/async rule engine with configurable packs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/config-loader.d.ts",
      "import": "./dist/config-loader.js",
      "require": "./dist/config-loader.cjs"
    }
  },
  "bin": {
    "stet": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/config-loader.ts src/cli.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "compromise": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "compromise": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  }
}
